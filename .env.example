# =============================================================================
# Bullet Memory — Environment Configuration Example
# Copy to .env and fill in your values.
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | ollama
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5-coder:7b

# ── Ollama (required when LLM_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama) ───
OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI (required when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai) ──
# OPENAI_API_KEY=sk-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: openai | ollama
# nomic-embed-text (ollama) → 768 dims
# text-embedding-3-small (openai) → 1536 dims
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./bullet_memory.db

# ── Vector Store ──────────────────────────────────────────────────────────────
# Options: chroma | in_memory
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=./chroma_db

# ── Memory Configuration ──────────────────────────────────────────────────────
IMPORTANCE_THRESHOLD=0.4
SIMILARITY_THRESHOLD=0.75
TOP_K_RETRIEVAL=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
